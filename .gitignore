*.hdf5

# 压缩包与归档
*.zip
*.tar
*.tar.gz
*.tgz
*.tbz2
*.7z
*.rar

# 日志与本地数据库
*.log
*.db
*.db-wal

# 操作系统
.DS_Store
Thumbs.db

# 本地调试与跑实验产出（不入库）
/debug/
/results/
